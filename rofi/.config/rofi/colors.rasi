/* Gruvbox */

* {
    background:              #282828;
    foreground:              #ebdbb2;
    active-border:           #cc241d;
    element-selected:        #665c54;
    green:                   #98971a;
    yellow:                  #d79921;
    blue:                    #458588;
    bright-blue:             #83a598;
    magenta:                 #b16286;
    bright-magenta:          #d3869b;
    cyan:                    #689d6a;
    bright-cyan:             #8ec07c;
}
